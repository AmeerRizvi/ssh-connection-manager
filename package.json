{
  "name": "ssh-connection-manager",
  "displayName": "SSH Connection Manager",
  "description": "Manage your SSH connections directly in VS Code with a clean, expandable interface",
  "version": "1.0.0",
  "publisher": "ameerrizvi",
  "engines": {
    "vscode": "^1.101.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AmeerRizvi/ssh-connection-manager.git"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ssh",
    "connection",
    "terminal",
    "remote",
    "server",
    "manager"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sshManager",
          "title": "SSH",
          "icon": "media/ssh.svg"
        }
      ]
    },
    "views": {
      "sshManager": [
        {
          "id": "sshView",
          "name": "Connections"
        }
      ]
    },
    "commands": [
      {
        "command": "sshManager.open",
        "title": "Connect",
        "icon": "$(arrow-right)"
      },
      {
        "command": "sshManager.add",
        "title": "Add Connection",
        "icon": "$(add)"
      },
      {
        "command": "sshManager.rename",
        "title": "Rename",
        "icon": "$(edit)"
      },
      {
        "command": "sshManager.delete",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "sshManager.editCommand",
        "title": "Edit Command",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "sshManager.open",
          "when": "view == sshView && viewItem == sshConnection",
          "group": "inline@1"
        }
      ],
      "view/title": [
        {
          "command": "sshManager.add",
          "when": "view == sshView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.102.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
